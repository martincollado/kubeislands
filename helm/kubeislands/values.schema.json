{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KubeIslands Helm chart values",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "frontend": {
      "type": "object",
      "properties": {
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
          },
          "required": ["repository", "tag"]
        },
        "replicas": { "type": "integer", "minimum": 1 },
        "resources": { "type": "object" },
        "service": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
            "port": { "type": "integer" }
          }
        }
      }
    },
    "engine": {
      "type": "object",
      "properties": {
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
          },
          "required": ["repository", "tag"]
        },
        "replicas": { "type": "integer", "minimum": 1 },
        "resources": { "type": "object" },
        "service": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "port": { "type": "integer" }
          }
        },
        "watchNamespaces": { "type": "string" },
        "resyncSeconds": { "type": "integer", "minimum": 5 }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "host": { "type": "string" },
        "tls": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "secretName": { "type": "string" }
          }
        }
      },
      "required": ["enabled"]
    },
    "rbac": {
      "type": "object",
      "properties": {
        "clusterScoped": { "type": "boolean" }
      },
      "required": ["clusterScoped"]
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    }
  }
}
